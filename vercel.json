{
    "rewrites": [
        { "source": "/((?!models/).*)", "destination": "/index.html" }
    ],
    "headers": [
        {
            "source": "/(.*).glb",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "model/gltf-binary"
                }
            ]
        },
        {
            "source": "/(.*).gltf",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "model/gltf+json"
                }
            ]
        }
    ]
}
